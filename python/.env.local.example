# 本机 / 局域网联调（不用 Docker）。复制为 python/.env.local（勿提交 Git）：
#   cp .env.local.example .env.local
#
# 终端 1：cd python && python run.py
# 终端 2（可选）：celery worker；或设 CELERY_TASK_ALWAYS_EAGER=1 免起 worker

HTTP_HOST=0.0.0.0
HTTP_PORT=8765
HTTP_RELOAD=1

REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# 仅本机调试、不想起 worker 时可设为 1
CELERY_TASK_ALWAYS_EAGER=0

DATABASE_URL=mysql+pymysql://root:PASSWORD@127.0.0.1:3306/feishu_keyword?charset=utf8mb4
DATABASE_RUN_MIGRATIONS=1
ASYNC_TASK_DB_AUTO_CREATE=0
ASYNC_DISPATCH_HTTP_ENABLED=1
ASYNC_SCHEDULE_BEAT_ENABLED=0
