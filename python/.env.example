# 复制为 .env 后按需填写（勿提交 .env）

# --- 统一 HTTP（python/run.py）---
HTTP_HOST=0.0.0.0
HTTP_PORT=8765
# HTTP_RELOAD=1

# --- 大加拉等 API（可选，不填则用代码内默认）---
DOUYIN_GENERAL_URL=
XHS_GENERAL_URL=

# --- Celery（异步/定时任务）---
REDIS_URL=redis://127.0.0.1:6379/0
# 留空则与 REDIS_URL 相同
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# 开发调试可设为 1，任务同步执行不落 Redis
CELERY_TASK_ALWAYS_EAGER=0
# 是否加载 celery_jobs/schedules.py 中的 beat 示例（默认关）
CELERY_BEAT_ENABLED=0
