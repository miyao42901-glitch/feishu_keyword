# 复制为 .env 后按需填写（勿提交 .env）

# --- 统一 HTTP（python/run.py）---
HTTP_HOST=0.0.0.0
HTTP_PORT=8765
# HTTP_RELOAD=1

# --- 大加拉等 API（可选，不填则用代码内默认）---
DOUYIN_GENERAL_URL=
XHS_GENERAL_URL=

# --- Celery（异步/定时任务）---
REDIS_URL=redis://127.0.0.1:6379/0
# 留空则与 REDIS_URL 相同
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# 开发调试可设为 1，任务同步执行不落 Redis
CELERY_TASK_ALWAYS_EAGER=0
# 是否加载 social_platform/tasks/beat_schedule.py 中的 beat 示例（默认关）
CELERY_BEAT_ENABLED=0

# --- 异步任务（MySQL）---
# 示例：mysql+pymysql://user:pass@127.0.0.1:3306/dbname?charset=utf8mb4
DATABASE_URL=
# 开发环境可在启动时自动建表（生产请用迁移工具）
ASYNC_TASK_DB_AUTO_CREATE=0
# GET .../results 默认每页条数（可用 query limit 覆盖，最大 200）
ASYNC_RESULTS_DEFAULT_LIMIT=20

# --- 异步任务提交前：yddm 用户校验（GET users/me）---
# YDDM_USERS_ME_URL=https://api.yddm.com/users/me
# YDDM_USERS_ME_TIMEOUT_SEC=10
# 单用户 pending+running 任务数上限（达到则拒绝新提交，返回 429）
ASYNC_TASK_MAX_ACTIVE_PER_USER=10
