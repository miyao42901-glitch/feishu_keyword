# python 环境变量模板（可提交 Git）
#
# | 场景 | 用法 |
# |------|------|
# | 本机 / 局域网联调（不用 Docker） | cp .env.local.example .env.local |
# | Docker / 远端部署 | cp .env.test 或 .env.master → .env |
#
# 加载顺序：.env → .env.local（后者覆盖）
# 复制为 .env 仅当需要覆盖模板默认值时（勿提交 .env）

# --- 统一 HTTP（python/run.py）---
HTTP_HOST=0.0.0.0
HTTP_PORT=8765
# 多进程（与 HTTP_RELOAD 互斥）；生产也可用 gunicorn，见 DEPLOYMENT.md
# HTTP_WORKERS=4
# HTTP_RELOAD=1

# 第三方 API 地址见 http_api/constants.py（勿在此配置 *_GENERAL_URL）

# --- Celery（异步/定时任务）---
REDIS_URL=redis://127.0.0.1:6379/0
# 留空则与 REDIS_URL 相同（推荐；勿指向未启动的 RabbitMQ，否则会 WinError 10061）
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# 开发调试可设为 1，任务在当前进程同步执行（无需单独 celery worker）
CELERY_TASK_ALWAYS_EAGER=0
# Worker 池与并发（默认 gevent + 4，等价于 -P gevent -c 4 --prefetch-multiplier=1）
CELERY_WORKER_POOL=gevent
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_PREFETCH_MULTIPLIER=1
# 是否加载 social_platform/tasks/beat_schedule.py 中的 beat 示例（默认关）
CELERY_BEAT_ENABLED=0
# 异步任务 Redis ZSET 调度（默认关：run.py 已内置 HTTP 轮询；无 HTTP 时改为 1 并启动 celery beat）
ASYNC_SCHEDULE_BEAT_ENABLED=0
# HTTP 进程内扫描 Redis 调度（默认开，与 celery worker 配合即可）
ASYNC_DISPATCH_HTTP_ENABLED=1
# Worker 启动恢复后，是否立即 dispatch 到期任务（默认关闭，建议灰度开启）
ASYNC_RESTORE_DISPATCH_DUE_ON_STARTUP=0
# dispatching 锁 TTL（秒）
ASYNC_DISPATCH_LOCK_TTL_SECONDS=600
# 异步任务 Redis 快照最大 TTL（秒），默认 7 天，防止长期泄漏
ASYNC_TASK_REDIS_MAX_TTL_SECONDS=604800
ASYNC_DISPATCH_POLL_SECONDS=15
# running 超过该秒数未更新则视为僵死并重置为 pending（默认 1800）
# ASYNC_TASK_RUNNING_STALE_SECONDS=1800

# 生产推荐避免双调度：
# ASYNC_DISPATCH_HTTP_ENABLED=1
# ASYNC_SCHEDULE_BEAT_ENABLED=0

# --- 异步任务（MySQL）---
# 示例：mysql+pymysql://user:pass@127.0.0.1:3306/dbname?charset=utf8mb4
DATABASE_URL=
# 开发环境可在启动时自动建表（生产请用迁移工具）
ASYNC_TASK_DB_AUTO_CREATE=0
# HTTP 启动时自动执行 feishu_async_tasks 列迁移（interval_minutes / fetch_count）
DATABASE_RUN_MIGRATIONS=1
# GET .../results 默认每页条数（可用 query limit 覆盖，最大 200）
ASYNC_RESULTS_DEFAULT_LIMIT=20

# --- 异步任务提交前：yddm 用户校验（GET users/me）---
# YDDM_USERS_ME_URL=https://api.yddm.com/users/me
# YDDM_USERS_ME_TIMEOUT_SEC=10
# 单用户 pending+running 任务数上限（达到则拒绝新提交，返回 429）
ASYNC_TASK_MAX_ACTIVE_PER_USER=10

# --- search-all 翻页止损（PR1：防无限翻页 / Worker 长时间阻塞）---
ASYNC_SEARCH_ALL_MAX_PAGES=50
ASYNC_SEARCH_ALL_MAX_RUN_SECONDS=900
ASYNC_SEARCH_DUPLICATE_PAGE_THRESHOLD=5
# 1=仅 Celery 异步 search-all 启用严格止损；0=同步/异步均启用
ASYNC_SEARCH_GUARDS_ASYNC_ONLY=1
