# 本机 / 局域网联调覆盖（复制为仓根 .env.local，勿提交 Git）
# 先：cp .env.test .env  再：cp .env.local.example .env.local

ENVIRONMENT=local

DATABASE_URL=mysql+pymysql://root:PASSWORD@127.0.0.1:3306/feishu_keyword?charset=utf8mb4

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://127.0.0.1:6379/0

HTTP_HOST=0.0.0.0
HTTP_PORT=8765
HTTP_RELOAD=1
CELERY_TASK_ALWAYS_EAGER=0
DATABASE_RUN_MIGRATIONS=1
ASYNC_TASK_DB_AUTO_CREATE=0
ASYNC_DISPATCH_HTTP_ENABLED=1
ASYNC_SCHEDULE_BEAT_ENABLED=0

YDDM_PROXY_TARGET=https://api.yddm.com
# 开发：Vite 代理 /api/v1 → 测试 API 域名（勿用局域网 IP，如 192.168.x.x:8765）
API_PUBLIC_HOST=test-fskw.tbpf.com
FEISHU_PUBLIC_HOST=test-fskw-feishu.tbpf.com
SYNC_PROXY_TARGET=https://test-fskw.tbpf.com

# 本地 dev 走 Vite 代理，必须清空以覆盖 .env.master / .env.test 里的域名
VITE_YDDM_API_BASE=
VITE_SYNC_API_BASE=
