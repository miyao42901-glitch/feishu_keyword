# 飞书关键词 — Nginx 反向代理示例（本地 / 局域网）
# 用法：复制为 sites-enabled 或 include 进主配置，按环境改 server_name、upstream

upstream feishu_frontend {
    server 127.0.0.1:5173;
}

upstream feishu_api {
    server 127.0.0.1:8765;
}

upstream yddm_billing {
    server api.yddm.com:443;
}

server {
    listen 80;
    server_name 192.168.1.24;

    client_max_body_size 20m;

    location /api/v1/ {
        proxy_pass http://feishu_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
    }

    location /yddm-api/ {
        proxy_pass https://yddm_billing/;
        proxy_ssl_server_name on;
        proxy_http_version 1.1;
        proxy_set_header Host api.yddm.com;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://feishu_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
