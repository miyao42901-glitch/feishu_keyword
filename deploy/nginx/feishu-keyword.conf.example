# 飞书关键词 — Nginx 反向代理示例
# 用法：
#   1. 复制为 sites-enabled 或 include 进主配置
#   2. 按环境改 server_name、upstream 地址、root/dist 路径
#   3. 前端 .env：VITE_API_BASE_URL=http://<本 server_name>（无 /api）
#      勿配置 VITE_SYNC_API_BASE（走同源 /api/v1 → 8765）
#      VITE_YDDM_API_BASE=/yddm-api 或留空（生产默认 /yddm-api）
#   4. npm run build 后 root 指向 feishu/dist；开发可把 / 代理到 5173

upstream feishu_frontend {
    # 生产：静态资源
    # server 127.0.0.1:8080;
    # 开发：Vite
    server 127.0.0.1:5173;
}

upstream feishu_backend {
    server 127.0.0.1:8000;
}

upstream yddm_billing {
    server 192.168.1.11:8001;
}

upstream sync_collection {
    server 192.168.1.11:8765;
}

server {
    listen 80;
    server_name 192.168.1.24;

    client_max_body_size 20m;

    # YDDM 采集：/api/v1/async/tasks、sync search-page 等（必须写在 /api/ 之前）
    location /api/v1/ {
        proxy_pass http://sync_collection;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
    }

    # 飞书任务后端：/api/feishu-task-configs 等
    location /api/ {
        proxy_pass http://feishu_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # YDDM 登录 / 计费（与 vite 一致：去掉 /yddm-api 前缀）
    location /yddm-api/ {
        proxy_pass http://yddm_billing/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://feishu_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
