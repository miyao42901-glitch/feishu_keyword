# 飞书插件局域网联调。复制为 feishu/.env.local 后执行 npm run dev:lan
# 将 192.168.1.11 改为运行 server / python 的本机局域网 IP

VITE_API_BASE_URL=http://192.168.1.11:8000

# 内网直连 sync-api（:8765）且已开 CORS 时取消注释；否则走 Vite 代理 /api/v1
VITE_SYNC_API_BASE=http://192.168.1.11:8765

# YDDM：Vite dev 反代到内网上游（与 vite.config.ts 中 YDDM_PROXY_TARGET 一致）
YDDM_PROXY_TARGET=http://192.168.1.11:8001
