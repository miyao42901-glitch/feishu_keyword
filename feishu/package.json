{
  "name": "feishu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:prod": "cross-env VITE_API_BASE_URL=https://fskw-feishu.tbpf.com YDDM_PROXY_TARGET=https://api.yddm.com SYNC_PROXY_TARGET=https://fskw-feishu.tbpf.com vite",
    "dev:test": "cross-env VITE_API_BASE_URL=https://test-fskw-feishu.tbpf.com YDDM_PROXY_TARGET=https://api.yddm.com SYNC_PROXY_TARGET=https://test-fskw-feishu.tbpf.com vite",
    "dev:local": "cross-env VITE_API_BASE_URL=http://127.0.0.1:8000 YDDM_PROXY_TARGET=https://api.yddm.com SYNC_PROXY_TARGET=http://192.168.1.11:8765 vite",
    "dev:lan": "vite",
    "build": "vue-tsc -b && vite build",
    "build:public": "npm run build:public:test",
    "build:public:test": "cross-env VITE_API_BASE_URL=https://test-fskw-feishu.tbpf.com npm run build && node ./scripts/copy-dist-to-public.mjs",
    "build:public:prod": "cross-env VITE_API_BASE_URL=https://fskw-feishu.tbpf.com npm run build && node ./scripts/copy-dist-to-public.mjs",
    "build:github": "npm run build:github:test",
    "build:github:test": "cross-env VITE_API_BASE_URL=https://test-fskw-feishu.tbpf.com npm run build && node ./scripts/prepare-github-release.mjs",
    "build:github:prod": "cross-env VITE_API_BASE_URL=https://fskw-feishu.tbpf.com npm run build && node ./scripts/prepare-github-release.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@lark-base-open/js-sdk": "^1.0.2",
    "dayjs": "^1.11.20",
    "element-plus": "^2.13.7",
    "pinia": "^3.0.4",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  }
}
