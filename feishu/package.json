{
  "name": "feishu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "output": "dist",
  "scripts": {
    "dev": "vite",
    "dev:prod": "vite",
    "dev:test": "vite",
    "dev:local": "vite",
    "dev:lan": "vite",
    "build": "vue-tsc -b && vite build",
    "build:public": "npm run build:public:test",
    "build:public:test": "npm run build && node ./scripts/copy-dist-to-public.mjs",
    "build:public:prod": "npm run build && node ./scripts/copy-dist-to-public.mjs",
    "build:github": "npm run build:github:test",
    "build:github:test": "npm run build && node ./scripts/prepare-github-release.mjs",
    "build:github:prod": "npm run build && node ./scripts/prepare-github-release.mjs",
    "push:plugin-static": "node ./scripts/push-github-main.mjs",
    "release:plugin-static:prod": "npm run build:github:prod && npm run push:plugin-static",
    "preview": "vite preview"
  },
  "dependencies": {
    "@lark-base-open/js-sdk": "^1.0.2",
    "dayjs": "^1.11.20",
    "element-plus": "^2.13.7",
    "pinia": "^3.0.4",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  }
}
