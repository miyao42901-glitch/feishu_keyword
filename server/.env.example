# server 环境变量模板（可提交 Git）
#
# | 场景 | 用法 |
# |------|------|
# | 本机 / 局域网联调（不用 Docker） | cp .env.local.example .env.local |
# | Docker / 远端部署 | cp .env.test 或 .env.master → .env，见 docs/DEPLOY.md |
#
# 加载顺序：.env → .env.local（后者覆盖，仅本地存在时）

# --- 以下为 Docker / traefik 部署参考（本地开发请用 .env.local.example）---

APT_DEBIAN_MIRROR=mirrors.aliyun.com
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
PYTHON_IMAGE=python:3.9-slim

ENVIRONMENT=dev

DATABASE_URL=mysql+pymysql://root:PASSWORD@tbpf-mysql:3306/feishu_keyword?charset=utf8mb4

REDIS_HOST=tbpf-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=2

API_PUBLIC_HOST=test-fskw.tbpf.com
ADMIN_PUBLIC_HOST=test-fskw-admin.tbpf.com
FEISHU_PUBLIC_HOST=test-fskw-feishu.tbpf.com
TRAEFIK_API_ROUTER_NAME=test-fkw-api
TRAEFIK_SYNC_ROUTER_NAME=test-fkw-sync
TRAEFIK_ADMIN_ROUTER_NAME=test-fkw-admin
TRAEFIK_FEISHU_ROUTER_NAME=test-fkw-feishu
