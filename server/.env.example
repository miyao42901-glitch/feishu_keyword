# -----------------------------------------------------------------------------
# 本地环境变量模板：复制本文件为同目录下的 .env 并填写真实值。
# 勿提交 .env。库名、表结构说明见项目 docs/DATABASE.md。
# -----------------------------------------------------------------------------

# 完整连接串（与 docs/DATABASE.md 第一节一致）
# XAMPP/WAMP 常见 root 且无密码时可参考：
# DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/feishu_keyword?charset=utf8mb4

DATABASE_URL=mysql+pymysql://USER:PASSWORD@127.0.0.1:3306/feishu_keyword?charset=utf8mb4

# -----------------------------------------------------------------------------
# Docker / Traefik（部署机整理为 server/.env.master；栈根 cp -f server/.env .env）
# -----------------------------------------------------------------------------
API_PUBLIC_HOST=feishukeyword.tbpf.com
TRAEFIK_API_ROUTER_NAME=fkw-api
TRAEFIK_ADMIN_ROUTER_NAME=fkw-admin

MYSQL_DB=feishu_keyword
MYSQL_USER=fkw
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

PYTHON_IMAGE=python:3.11-slim
PIP_INDEX_URL=
MYSQL_PUBLISH_PORT=3306
