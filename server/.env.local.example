# 本机 / 局域网联调（不用 Docker）。复制为 server/.env.local（勿提交 Git）：
#   cp .env.local.example .env.local
#
# 启动：cd server && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
# 前端：admin / feishu 使用各自 .env.local，npm run dev:lan

ENVIRONMENT=local

# 本机 MySQL（或局域网内数据库主机 IP:3306）
DATABASE_URL=mysql+pymysql://root:PASSWORD@127.0.0.1:3306/feishu_keyword?charset=utf8mb4

# 本机 Redis（与 python/.env.local 中 REDIS_URL 的库号建议一致）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
