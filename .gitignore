# 本地残留目录（勿提交）
/web/

# public：admin / feishu 预编译产物随主仓提交（CI 仅 rsync，Runner 无需 Node）
/public/*
!/public/admin/
!/public/admin/**
!/public/feishu/
!/public/feishu/**
# 若 public/feishu 内嵌 GitHub 发布用 .git，勿进主仓
/public/feishu/.git/

# Docker 本地数据卷
/data/

# 参考资料目录（仅本地查看，勿提交）
/references/

# ------------------------------------------------------------------
# 本地访问 / 私密配置（数据库连接、本机 API、个人 token 等，勿提交）
# ------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
# 任意子目录下的环境文件（保留 *.example / *.sample 模板）
**/.env
!**/.env.example
!**/.env.sample
