# 本地残留目录（勿提交）
/web/

# public：admin / feishu 预编译产物（可提交；CI Runner 部署时会重新编译，非必须提交）
/public/*
!/public/admin/
!/public/admin/**
!/public/feishu/
!/public/feishu/**
