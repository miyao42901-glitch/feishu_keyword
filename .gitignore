# 本地残留目录（勿提交）
/web/

# public：admin 随主仓；feishu 为构建产物 + GitHub 手动发布（内嵌 .git），不进主仓
/public/*
!/public/admin/
!/public/admin/**

# Docker 本地数据卷
/data/

# 参考资料目录（仅本地查看，勿提交）
/references/

# ------------------------------------------------------------------
# 本地访问 / 私密配置（数据库连接、本机 API、个人 token 等，勿提交）
# ------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
# 任意子目录下的环境文件（保留 *.example / *.sample 模板）
**/.env
!**/.env.example
!**/.env.sample
