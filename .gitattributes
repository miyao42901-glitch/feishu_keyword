# Normalize text to LF in the repository; checkout as LF on all platforms.
* text=auto eol=lf

*.sh text eol=lf

# Windows-native scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.webm binary
*.pdf binary
*.zip binary
*.gz binary
*.sqlite binary
*.db binary
