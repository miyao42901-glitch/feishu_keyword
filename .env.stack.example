# 各环境栈根 .env 示例（测试：/docker/feishu_keyword-test/.env，正式：/docker/feishu_keyword/.env）
# 部署惯例：cp -f server/.env .env && chmod 600 .env
# CI 不 rsync 本文件；真实 MYSQL_ROOT_PASSWORD / DATABASE_URL 仅写在服务器。

# --- 可选：运维脚本 docker exec tbpf-mysql 用（与 /docker/traefik/.env 中 MYSQL_ROOT_PASSWORD 一致）---
MYSQL_ROOT_PASSWORD=your_root_password

# --- Compose 插值（与 server/.env.test|master 一致）---
APT_DEBIAN_MIRROR=mirrors.aliyun.com
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
PYTHON_IMAGE=

ENVIRONMENT=test

DATABASE_URL=mysql+pymysql://root:your_root_password@tbpf-mysql:3306/feishu_keyword?charset=utf8mb4

REDIS_HOST=tbpf-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=2

API_PUBLIC_HOST=test-fskw.tbpf.com
ADMIN_PUBLIC_HOST=test-fskw-admin.tbpf.com
FEISHU_PUBLIC_HOST=test-fskw-feishu.tbpf.com
TRAEFIK_API_ROUTER_NAME=test-fkw-api
TRAEFIK_SYNC_ROUTER_NAME=test-fkw-sync
TRAEFIK_ADMIN_ROUTER_NAME=test-fkw-admin
TRAEFIK_FEISHU_ROUTER_NAME=test-fkw-feishu
